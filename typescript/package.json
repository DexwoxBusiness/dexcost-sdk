{
  "name": "@dexcost/sdk",
  "version": "0.4.2",
  "description": "Agent Unit Economics SDK for Node.js",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dexcost": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs && node scripts/build-cjs.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "decimal.js": "^10.6.0",
    "js-yaml": "^4.1.1"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "ai": ">=3.0.0",
    "better-sqlite3": ">=11.0.0",
    "openai": ">=4.0.0",
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "ai",
    "agents",
    "cost-tracking",
    "llm",
    "observability"
  ],
  "license": "MIT",
  "homepage": "https://docs.dexcost.io/docs/sdks/typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DexwoxBusiness/dexcost-sdk.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/DexwoxBusiness/dexcost-sdk/issues"
  }
}
